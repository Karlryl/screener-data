{
  "name": "screener-data",
  "version": "0.1.0",
  "private": true,
  "description": "Yahoo-Pull-Pipeline für Karls v7.3 Stock-Screener.",
  "main": "pull-yahoo.js",
  "scripts": {
    "pull": "node pull-yahoo.js --watchlist watchlist.json --output snapshots --rate-limit 1500",
    "pull:fast": "node pull-yahoo.js --watchlist watchlist.json --output snapshots --rate-limit 500",
    "pull:single": "node pull-yahoo.js --watchlist watchlist.json --output snapshots-single --rate-limit 100"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "yahoo-finance2": "^3.14.0"
  },
  "license": "Proprietary"
}
