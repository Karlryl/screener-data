node_modules/
*.log
.DS_Store
.env

# ── Generated HTML artifacts ─────────────────────────────────────────
# methods-report.html is deprecated (replaced by outputs/methodology-report.md).
# 27 MB per run × daily commits = repo bloat. Regenerate locally with:
#   node generate-methods-report.js (if it still exists)
methods-report.html

# dashboard.html is a supplementary view not linked from index.html.
# Gitignored to reduce daily commit size. Still generated on the runner.
dashboard.html

# ── fundamentals-cache ───────────────────────────────────────────────
# 28-day local cache; not needed in git history, rebuilt on each runner.
fundamentals-cache/

# Tag 133k: SEC XBRL cache lives on the runner; only _manifest.json is committed
external-data/sec-xbrl/*.json
!external-data/sec-xbrl/_manifest.json

# Tag 134 — Phase 5.1: archive of old methods-history / picks-history / prices snapshots
external-data/methods-history-archive/
external-data/picks-history-archive/
external-data/prices-archive/

# Tag 134 — Phase 5.2: methodHistory subtree moved out of alert-state.json
# (was bloating git by ~25 MB per push). Rebuildable from methods-history/.
external-data/method-history-state.json

# Tag 150: outputs/ contains daily-regenerated reports; committed via gh-pages only.
# .gitkeep keeps the directory tracked so scripts can write without mkdir.
outputs/
!outputs/.gitkeep

# Tag 151: snapshots/ is regenerated fresh every run — no need to commit 3528 files.
# _manifest.json is kept so the quality gate can read n_ok after a run.
snapshots/
!snapshots/_manifest.json
snapshots/_manifest-full.json

# Tag 168: pipeline-health/ is transient per-run state written by the 3 pipeline scripts.
# Consumed by scripts/pipeline-health-check.js on the same runner, not needed in git history.
pipeline-health/
